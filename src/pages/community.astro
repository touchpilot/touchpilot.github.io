---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import PageHeader from "@components/PageHeader.astro";

const channels = [
  { title: "GitHub", description: "Source code, issues, feature requests, and discussions.", href: "https://github.com/touchpilot/touchpilot", cta: "github.com/touchpilot/touchpilot" },
  { title: "Discord", description: "Chat with maintainers and other contributors in real time.", href: "https://discord.gg/TvXwsNbx", cta: "discord.gg/TvXwsNbx" },
  { title: "Documentation", description: "Architecture, skills, tool spec, workflows, MCP, validation.", href: "https://touchpilot.github.io/touchpilot-docs/", cta: "touchpilot.github.io/touchpilot-docs" },
  { title: "Contributing", description: "Read the contributor guide before opening a pull request.", href: "https://github.com/touchpilot/touchpilot/blob/main/CONTRIBUTING.md", cta: "CONTRIBUTING.md" },
];
---
<Base
  title="Community"
  description="Get involved with TouchPilot — GitHub, Discord, documentation, and how to contribute."
>
  <Header slot="header" current="community" />
  <Footer slot="footer" />

  <PageHeader
    eyebrow="Community"
    title="Talk to us, build with us, report with us."
    subtitle="TouchPilot is built in the open. Pick the channel that fits what you want to do."
  />

  <div class="grid gap-6 sm:grid-cols-2">
    {channels.map((c) => (
      <a
        href={c.href}
        class="group rounded-lg border bg-card p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg"
      >
        <h3 class="text-lg font-semibold">{c.title}</h3>
        <p class="mt-2 text-sm text-muted-foreground">{c.description}</p>
        <p class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary transition-all group-hover:border-b-2 group-hover:border-primary">
          {c.cta}
          <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
            <path d="M5 12h14m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </p>
      </a>
    ))}
  </div>

  <section class="mt-16 rounded-lg border bg-muted/50 p-6">
    <h2 class="text-xl font-semibold">License</h2>
    <p class="mt-2 text-sm text-muted-foreground">
      TouchPilot is released under the <strong>MIT License</strong>. You can
      use it, fork it, ship your own version. Just keep the copyright and
      license notice.
    </p>
  </section>
</Base>