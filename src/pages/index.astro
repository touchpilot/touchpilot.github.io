---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import Badge from "@components/ui/Badge.astro";

const pillars = [
  {
    title: "See",
    description: "Observe UI semantics via AccessibilityService",
    icon: "M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8zM12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6z",
  },
  {
    title: "Act",
    description: "Tap, type, scroll, open apps, and more",
    icon: "M9 11.24V7.5a3.5 3.5 0 1 1 7 0v3.74M5 9h14l1 12H4l1-12z",
  },
  {
    title: "Safe",
    description: "Permissioned tools with risk levels",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  },
  {
    title: "Observable",
    description: "Every decision and action is logged",
    icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8",
  },
  {
    title: "Chat",
    description: "OpenAI-compatible models today, local models later",
    icon: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z",
  },
];

const traits = [
  { icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5", title: "Modular", desc: "Pluggable tools, skills, and providers" },
  { icon: "M9 12l2 2 4-4M12 3 4 6v6c0 4.4 3 8.4 8 9 5-.6 8-4.6 8-9V6l-8-3z", title: "Secure by design", desc: "Approvals, risk levels, and policy controls" },
  { icon: "M2 4h20v16H2zM6 8h.01M10 8h.01M14 8h.01M18 8h.01M6 12h.01M10 12h.01M14 12h.01M18 12h.01M6 16h12", title: "Local first", desc: "Logs, skills, and sessions stored on-device" },
  { icon: "M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09zM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z", title: "Early stage", desc: "MVP: AccessibilityService spike and agent runtime" },
];

const howItWorks = [
  { n: "1", title: "Sideload the APK", body: "Download TouchPilot from GitHub Releases. No Play Store needed. Works on real phones and emulators." },
  { n: "2", title: "Grant Accessibility", body: "Standard Accessibility service — how the agent reads your screen and performs taps. No root, no overlay hacks." },
  { n: "3", title: "Chat your task", body: "Open Wi-Fi settings, draft a text, change volume. The agent proposes a typed tool call." },
  { n: "4", title: "Approve what matters", body: "LOW tools run silent. MEDIUM asks once per session. HIGH always asks. You see every argument." },
];
---
<Base
  title="TouchPilot"
  description="Local-first Android AI agent runtime for safe, observable phone control. Open source, on-device, auditable."
>
  <Header slot="header" current="home" />
  <Footer slot="footer" />

  <!-- Hero -->
  <section class="container py-20 md:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
      <!-- Left: text -->
      <div class="space-y-6 text-center lg:text-left">
        <div class="flex justify-center lg:justify-start">
          <Badge variant="secondary" class="px-3 py-1 text-xs">
            <span class="mr-1.5 inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-primary"></span>
            1.0 Release Candidate · Live now
          </Badge>
        </div>

        <div class="flex items-center justify-center gap-4 lg:justify-start">
          <img src="/app-icon.png" alt="TouchPilot" class="h-16 w-16 rounded-2xl shadow-lg shadow-primary/20 ring-1 ring-primary/20" />
          <h1 class="text-5xl font-bold tracking-tight md:text-6xl lg:text-7xl">
            <span class="gradient-text">TouchPilot</span>
          </h1>
        </div>

        <p class="text-2xl font-medium leading-snug md:text-3xl">
          Android-native AI agent runtime
          <br />
          for <span class="gradient-text font-semibold">safe, observable</span> phone control.
        </p>

        <p class="max-w-xl text-lg leading-relaxed text-muted-foreground mx-auto lg:mx-0">
          TouchPilot lets AI agents perceive and operate Android devices
          through explicit, permissioned, and inspectable tools.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3 lg:justify-start">
          <Button size="lg" href="/install/">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
              <path d="M12 4v12m0 0-5-5m5 5 5-5M5 20h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Download APK
          </Button>
          <Button size="lg" variant="outline" href="https://github.com/touchpilot/touchpilot">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.18c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.13 2.86.39 2.18-1.49 3.15-1.18 3.15-1.18.63 1.58.23 2.75.11 3.04.73.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/>
            </svg>
            View on GitHub
          </Button>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 pt-2 text-xs text-muted-foreground lg:justify-start">
          <span class="inline-flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19l12-12-1.41-1.41z"/></svg>
            Android 8.0+
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19l12-12-1.41-1.41z"/></svg>
            MIT licensed
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19l12-12-1.41-1.41z"/></svg>
            No account
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19l12-12-1.41-1.41z"/></svg>
            No telemetry
          </span>
        </div>
      </div>

      <!-- Right: phone mockup -->
      <div class="relative z-10 flex justify-center lg:justify-end">
        <div class="absolute -inset-8 -z-10 rounded-full bg-gradient-to-br from-primary/20 via-transparent to-primary/10 blur-3xl"></div>
        <img
          src="/phone-chat.png"
          alt="TouchPilot chat interface on Android"
          class="w-full max-w-md rounded-[2.5rem] shadow-2xl shadow-primary/20 ring-1 ring-primary/10"
        />
      </div>
    </div>
  </section>

  <!-- Five pillars (See / Act / Safe / Observable / Chat) -->
  <section class="container py-16">
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-3 lg:grid-cols-5">
      {pillars.map((p) => (
        <div class="flex flex-col items-center text-center">
          <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary/15 text-primary ring-1 ring-primary/20">
            <svg viewBox="0 0 24 24" fill="none" class="h-7 w-7" aria-hidden="true">
              <path d={p.icon} stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <h3 class="mt-4 text-base font-semibold">{p.title}</h3>
          <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Built for developers + phone mockup -->
  <section class="container py-16">
    <div class="grid items-center gap-10 rounded-3xl border bg-card p-8 shadow-sm md:p-12 lg:grid-cols-2">
      <!-- Left: terminal -->
      <div class="space-y-4">
        <p class="text-sm font-bold uppercase tracking-wider text-primary">Built for developers</p>
        <div class="overflow-hidden rounded-xl border bg-foreground font-mono text-sm shadow-lg">
          <div class="flex items-center gap-1.5 border-b border-background/20 bg-foreground px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-rose-500/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-500/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-primary/80"></span>
            <span class="ml-3 text-xs text-background/60">touchpilot</span>
          </div>
          <pre class="space-y-2 p-5 text-background"><code><span class="text-primary">#</span> Build debug APK
<span class="text-muted-foreground">$</span> ./gradlew assembleDebug

<span class="text-primary">#</span> Build release APK
<span class="text-muted-foreground">$</span> ./gradlew assembleRelease</code></pre>
        </div>
        <ul class="space-y-2 pt-2">
          {[
            "Runs natively on Android",
            "OpenAI-compatible providers",
            "Local inference (ExecuTorch, llama.cpp) coming",
            "Full audit logs and approvals",
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm">
              <svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 flex-none text-primary" fill="currentColor"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19l12-12-1.41-1.41z"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: phone mockup -->
      <div class="relative flex justify-center">
        <div class="absolute -inset-6 -z-10 rounded-full bg-primary/10 blur-3xl"></div>
        <img
          src="/phone-chat.png"
          alt="TouchPilot on device"
          class="w-full max-w-xs rounded-[2rem] shadow-2xl shadow-primary/10 ring-1 ring-border"
        />
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="container py-20 text-center sm:py-24">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">How it works</p>
    <h2 class="text-3xl font-bold md:text-4xl">
      From a downloaded APK to a working on-device agent in
      <span class="gradient-text">under five minutes</span>.
    </h2>
    <p class="mx-auto mt-4 mb-12 max-w-2xl text-lg text-muted-foreground">
      Every step is reversible. No root, no Play Store, no account.
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {howItWorks.map(({ n, title, body }) => (
        <Card class="bg-muted/50 text-left transition-all hover:-translate-y-1 hover:shadow-lg">
          <div class="space-y-3 p-6">
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary text-base font-bold text-primary-foreground">{n}</span>
            <h3 class="text-lg font-semibold">{title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{body}</p>
          </div>
        </Card>
      ))}
    </div>
  </section>

  <!-- Image gallery row: 3 phone mockups -->
  <section class="container py-12">
    <div class="grid gap-6 md:grid-cols-3">
      <div class="relative overflow-hidden rounded-2xl border bg-card p-4 shadow-sm">
        <img src="/phone-chat.png" alt="TouchPilot chat" class="w-full rounded-xl" />
        <p class="mt-3 text-center text-sm font-medium">Chat with the agent</p>
      </div>
      <div class="relative overflow-hidden rounded-2xl border bg-card p-4 shadow-sm">
        <img src="/phone-chat.png" alt="TouchPilot tool picker" class="w-full rounded-xl" />
        <p class="mt-3 text-center text-sm font-medium">Inspect every tool</p>
      </div>
      <div class="relative overflow-hidden rounded-2xl border bg-card p-4 shadow-sm">
        <img src="/phone-chat.png" alt="TouchPilot audit log" class="w-full rounded-xl" />
        <p class="mt-3 text-center text-sm font-medium">Read every action</p>
      </div>
    </div>
  </section>

  <!-- Traits row (Modular / Secure / Local / Early stage) -->
  <section class="container py-16">
    <div class="grid grid-cols-2 gap-x-8 gap-y-10 md:grid-cols-4">
      {traits.map((t) => (
        <div class="flex flex-col items-center text-center">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <svg viewBox="0 0 24 24" fill="none" class="h-7 w-7" aria-hidden="true">
              <path d={t.icon} stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <h3 class="mt-4 text-base font-semibold">{t.title}</h3>
          <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{t.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container py-16">
    <div class="relative overflow-hidden rounded-3xl border bg-gradient-to-br from-primary/10 via-card to-card p-10 text-center md:p-16">
      <div class="absolute -inset-1 -z-10 bg-gradient-to-br from-primary/20 to-transparent blur-2xl"></div>
      <img src="/app-icon.png" alt="TouchPilot" class="mx-auto h-20 w-20 rounded-3xl shadow-xl shadow-primary/20 ring-2 ring-primary/30" />
      <h2 class="mt-6 text-3xl font-bold tracking-tight md:text-4xl">
        Try <span class="gradient-text">TouchPilot</span> on your phone.
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-lg text-muted-foreground">
        Sideload the APK, grant Accessibility, and start a chat. You'll see
        every tool the agent runs and approve the ones that matter.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <Button size="lg" href="/install/">
          Install guide
          <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
            <path d="M5 12h14m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </Button>
        <Button size="lg" variant="outline" href="/features/">View features</Button>
      </div>
    </div>
  </section>
</Base>