---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import PageHeader from "@components/PageHeader.astro";
---
<Base
  title="Install"
  description="Sideload the TouchPilot APK on Android 8.0 and newer. Download, install, and grant Accessibility."
>
  <Header slot="header" current="install" />
  <Footer slot="footer" />

  <PageHeader
    eyebrow="Install"
    title="Sideload the APK and you're set."
    subtitle="TouchPilot ships as a signed Android APK. The 1.0 release is on GitHub Releases. Until Google Play is set up, you install it manually."
  />

  <div class="my-8 flex flex-wrap items-center gap-3">
    <a
      href="https://github.com/touchpilot/touchpilot/releases/latest"
      class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
    >
      <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
        <path d="M12 4v12m0 0-5-5m5 5 5-5M5 20h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Download latest APK
    </a>
    <a
      href="https://github.com/touchpilot/touchpilot/releases/latest"
      class="text-sm text-muted-foreground underline-offset-2 hover:underline"
    >
      View checksums on GitHub →
    </a>
  </div>

  <ol class="space-y-8">
    {[
      { n: 1, title: "Check the requirements", body: "Android 8.0 (API 26) or newer, about 80 MB free storage, and permission to install apps from unknown sources. TouchPilot works on real phones and emulators (Android Studio AVD, LDPlayer, BlueStacks, etc.)." },
      { n: 2, title: "Download the APK", body: "Open the latest release page, find the largest app-release.apk asset, and download it. Optionally verify the SHA-256 against the .sha256 file attached to the release." },
      { n: 3, title: "Install on your device", body: "On a phone, open the APK in your file manager or browser and tap Install. On an emulator, run adb install -r app-release.apk or drag the APK onto the emulator window." },
      { n: 4, title: "Grant Accessibility", body: "TouchPilot asks for the Accessibility permission on first run. This is how the agent reads your screen and performs taps. TouchPilot only requests the permissions it actually needs — see the safety page for the full list." },
      { n: 5, title: "Start a chat", body: 'Open TouchPilot, type what you want — "open wifi settings", "set media volume to 80 percent", "draft a text to Alex" — and watch the agent propose its first action.' },
    ].map(({ n, title, body }) => (
      <li class="grid gap-2 sm:grid-cols-[auto_1fr] sm:gap-6">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary/20 text-sm font-semibold text-primary">{n}</span>
        <div>
          <h3 class="text-lg font-semibold">{title}</h3>
          <p class="mt-1 text-muted-foreground" set:html={body}></p>
        </div>
      </li>
    ))}
  </ol>

  <div class="mt-12 rounded-lg border bg-muted/50 p-6">
    <h3 class="text-base font-semibold">Build from source</h3>
    <p class="mt-2 text-sm text-muted-foreground">
      Prefer to compile it yourself? Clone the repo and run:
    </p>
    <pre class="mt-3 overflow-x-auto rounded-md bg-foreground p-4 font-mono text-xs text-background"><code>git clone https://github.com/touchpilot/touchpilot.git
cd touchpilot
./gradlew assembleDebug      # or assembleRelease</code></pre>
  </div>

  <p class="mt-8 text-sm text-muted-foreground">
    Need the full guide, including troubleshooting and OEM-specific quirks?
    Read the <a href="https://touchpilot.github.io/touchpilot-docs/install/" class="text-primary underline-offset-2 hover:underline">install docs</a>.
  </p>
</Base>