---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import PageHeader from "@components/PageHeader.astro";
---
<Base
  title="Roadmap"
  description="Where TouchPilot is, where it's going, and what ships with 1.0."
>
  <Header slot="header" current="roadmap" />
  <Footer slot="footer" />

  <PageHeader
    eyebrow="Roadmap"
    title="From MVP to stable host, in public."
    subtitle="TouchPilot ships in the open. Milestones below are the canonical plan; pull requests and bug reports may reorder them."
  />

  <ol class="relative space-y-8 border-l border-border pl-6">
    {[
      { label: "Done", title: "Local-first Android agent foundation", body: "Chat UI, screen context, tool execution, audit log, AccessibilityService-based control.", status: "done" },
      { label: "Done", title: "Hybrid local AI core", body: "Deterministic local router, LiteRT-backed on-device model, OpenAI-compatible cloud fallback (opt-in).", status: "done" },
      { label: "Done", title: "Skills v2 registry", body: "Bundled skills for browser, settings, messages, Wi-Fi, volume, launcher, clipboard, and share.", status: "done" },
      { label: "Now", title: "1.0 release", body: "Signed APK, public documentation, skill authoring guide, safety model, release process.", status: "now" },
      { label: "Next", title: "Safety & policy v2", body: "Sensitive workflow classification, central policy decisions, app-aware rules, expanded redaction.", status: "next" },
      { label: "Then", title: "Post-1.0 platform", body: "Stable host for skills and workflows. Frozen tool, skill, workflow, memory, and policy contracts.", status: "then" },
    ].map((m) => (
      <li class="relative">
        <span class:list={["absolute -left-[33px] inline-flex h-6 w-6 items-center justify-center rounded-full ring-4 ring-background text-white", m.status === "done" ? "bg-brand-600" : m.status === "now" ? "bg-brand-600" : m.status === "next" ? "bg-amber-500" : "bg-muted-foreground"]}>
          <svg viewBox="0 0 24 24" fill="none" class="h-3 w-3" aria-hidden="true">
            <path d="m5 12 5 5L20 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <div class="flex flex-col gap-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">{m.label}</p>
          <h3 class="text-lg font-semibold">{m.title}</h3>
          <p class="text-sm text-muted-foreground">{m.body}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="mt-12 rounded-lg border bg-muted/50 p-6">
    <h3 class="text-base font-semibold">Want the granular plan?</h3>
    <p class="mt-2 text-sm text-muted-foreground">
      The full roadmap lives in the docs and is updated alongside every release.
    </p>
    <a
      href="https://touchpilot.github.io/touchpilot-docs/roadmap/"
      class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary transition-all hover:border-b-2 hover:border-primary"
    >
      Read the roadmap docs →
    </a>
  </div>
</Base>