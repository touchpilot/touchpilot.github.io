---
export interface Props {
  risk: "low" | "medium" | "high";
}
const { risk } = Astro.props;

const labels = {
  low: "Low",
  medium: "Medium",
  high: "High",
} as const;

const styles = {
  low:    "bg-brand-50 text-brand-700 ring-brand-200 dark:bg-brand-950/40 dark:text-brand-300 dark:ring-brand-800/60",
  medium: "bg-amber-50 text-amber-700 ring-amber-200 dark:bg-amber-950/40 dark:text-amber-300 dark:ring-amber-800/60",
  high:   "bg-rose-50 text-rose-700 ring-rose-200 dark:bg-rose-950/40 dark:text-rose-300 dark:ring-rose-800/60",
} as const;
---
<span class:list={["inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset", styles[risk]]}>
  <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
  {labels[risk]} risk
</span>