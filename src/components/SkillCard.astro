---
import RiskBadge from "./RiskBadge.astro";

export interface Props {
  skill: {
    id: string;
    title: string;
    description: string;
    risk: string;
    aliases: string[];
    examples: string[];
  };
}
const { skill } = Astro.props;
const firstExample = skill.examples[0];
---
<article class="group rounded-lg border bg-card p-6 text-card-foreground shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-lg">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold tracking-tight">{skill.title}</h3>
    <RiskBadge risk={skill.risk} />
  </div>
  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{skill.description}</p>

  {firstExample && (
    <p class="mt-4 rounded-md border bg-muted/50 px-3 py-2 font-mono text-xs text-muted-foreground">
      <span class="select-none text-primary">› </span>{firstExample}
    </p>
  )}

  {skill.aliases.length > 0 && (
    <ul class="mt-4 flex flex-wrap gap-1.5">
      {skill.aliases.slice(0, 4).map((alias) => (
        <li class="rounded-full bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
          {alias}
        </li>
      ))}
    </ul>
  )}
</article>