---
export interface Props {
  current?: "home" | "features" | "skills" | "install" | "safety" | "roadmap" | "community";
}
const { current = "home" } = Astro.props;

const links = [
  { id: "features",  href: "/features/",   label: "Features" },
  { id: "skills",    href: "/skills/",     label: "Skills" },
  { id: "install",   href: "/install/",    label: "Install" },
  { id: "safety",    href: "/safety/",     label: "Safety" },
  { id: "roadmap",   href: "/roadmap/",    label: "Roadmap" },
  { id: "community", href: "/community/",  label: "Community" },
] as const;
---
<header class="sticky top-0 z-40 border-b border-slate-200/60 bg-white/80 backdrop-blur dark:border-slate-800/60 dark:bg-slate-950/80">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white shadow-soft">
        <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
          <path d="M5 5c0-1.1.9-2 2-2h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5Z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M9 12h6M9 8h6M9 16h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="text-base">TouchPilot</span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1 text-sm">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "rounded-md px-3 py-2 transition-colors",
                current === link.id
                  ? "text-brand-700 dark:text-brand-300"
                  : "text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white",
              ]}
              aria-current={current === link.id ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/touchpilot/touchpilot"
        class="hidden items-center gap-1.5 rounded-md border border-slate-200 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 dark:border-slate-800 dark:text-slate-200 dark:hover:bg-slate-900 sm:inline-flex"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
          <path fill="currentColor" d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.18c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.13 2.86.39 2.18-1.49 3.15-1.18 3.15-1.18.63 1.58.23 2.75.11 3.04.73.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/>
        </svg>
        <span>Star</span>
      </a>
      <a
        href="/install/"
        class="inline-flex items-center gap-1.5 rounded-md bg-brand-600 px-3 py-2 text-sm font-medium text-white shadow-soft hover:bg-brand-700"
      >
        Download
      </a>
    </div>
  </div>
</header>