---
export interface Props {
  current?: "home" | "features" | "skills" | "install" | "safety" | "roadmap" | "community";
}
const { current = "home" } = Astro.props;

const links = [
  { id: "features",  href: "/features/",   label: "Features" },
  { id: "skills",    href: "/skills/",     label: "Skills" },
  { id: "install",   href: "/install/",    label: "Install" },
  { id: "safety",    href: "/safety/",     label: "Safety" },
  { id: "roadmap",   href: "/roadmap/",    label: "Roadmap" },
  { id: "community", href: "/community/",  label: "Community" },
] as const;
---
<header class="sticky border-b-[1px] top-0 z-40 w-full border-border bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <nav class="container flex h-14 items-center justify-between px-4">
    <!-- Brand -->
    <a href="/" class="ml-2 flex items-center gap-2 text-lg font-bold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center overflow-hidden rounded-lg bg-primary text-primary-foreground shadow-sm">
        <img src="/logo.png" alt="" class="h-6 w-6" />
      </span>
      <span>TouchPilot</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden gap-2 md:flex" aria-label="Primary">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded-md px-3 py-2 text-sm transition-colors",
            current === link.id
              ? "bg-accent text-accent-foreground"
              : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
          ]}
          aria-current={current === link.id ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden gap-2 md:flex">
      <a
        href="https://github.com/touchpilot/touchpilot"
        target="_blank"
        rel="noreferrer noopener"
        class="inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.18c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.13 2.86.39 2.18-1.49 3.15-1.18 3.15-1.18.63 1.58.23 2.75.11 3.04.73.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/>
        </svg>
        <span>GitHub</span>
      </a>

      <a
        href="/install/"
        class="inline-flex items-center justify-center gap-2 rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
      >
        Download
      </a>
    </div>

    <!-- Mobile menu (simplified) -->
    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none rounded-md p-2 hover:bg-accent">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/>
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-2 w-56 rounded-md border border-border bg-popover p-2 shadow-lg">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "block rounded-md px-3 py-2 text-sm transition-colors",
              current === link.id
                ? "bg-accent text-accent-foreground"
                : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
            ]}
          >
            {link.label}
          </a>
        ))}
        <div class="mt-2 border-t border-border pt-2">
          <a
            href="/install/"
            class="block rounded-md bg-primary px-3 py-2 text-center text-sm font-medium text-primary-foreground"
          >
            Download
          </a>
        </div>
      </div>
    </details>
  </nav>
</header>