---
const year = new Date().getFullYear();
---
<footer class="border-t border-slate-200/60 py-12 dark:border-slate-800/60">
  <div class="mx-auto grid w-full max-w-6xl gap-10 px-6 sm:grid-cols-2 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-semibold tracking-tight">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
            <path d="M5 5c0-1.1.9-2 2-2h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5Z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 12h6M9 8h6M9 16h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
        <span>TouchPilot</span>
      </div>
      <p class="mt-3 max-w-md text-sm text-slate-600 dark:text-slate-400">
        Local-first Android AI agent runtime for safe, observable phone control.
        Open source under the MIT license.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold">Product</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
        <li><a href="/features/" class="hover:text-slate-900 dark:hover:text-white">Features</a></li>
        <li><a href="/skills/" class="hover:text-slate-900 dark:hover:text-white">Skills</a></li>
        <li><a href="/install/" class="hover:text-slate-900 dark:hover:text-white">Install</a></li>
        <li><a href="/roadmap/" class="hover:text-slate-900 dark:hover:text-white">Roadmap</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold">Resources</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
        <li><a href="https://touchpilot.github.io/touchpilot-docs/" class="hover:text-slate-900 dark:hover:text-white">Documentation</a></li>
        <li><a href="https://github.com/touchpilot/touchpilot" class="hover:text-slate-900 dark:hover:text-white">Source on GitHub</a></li>
        <li><a href="https://discord.gg/TvXwsNbx" class="hover:text-slate-900 dark:hover:text-white">Discord</a></li>
        <li><a href="/safety/" class="hover:text-slate-900 dark:hover:text-white">Safety model</a></li>
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-10 flex w-full max-w-6xl flex-col items-start justify-between gap-3 px-6 text-sm text-slate-500 sm:flex-row sm:items-center dark:text-slate-400">
    <p>© {year} TouchPilot contributors. Released under the MIT License.</p>
    <p>
      Built with
      <a href="https://astro.build" class="underline-offset-2 hover:underline">Astro</a>
      · Hosted on
      <a href="https://pages.cloudflare.com" class="underline-offset-2 hover:underline">Cloudflare Pages</a>
    </p>
  </div>
</footer>