---
export interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  size?: "md" | "lg";
}
const {
  href = "/install/",
  variant = "primary",
  size = "md",
} = Astro.props;

const base = "inline-flex items-center justify-center gap-2 rounded-md font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2";
const sizing = size === "lg" ? "h-11 px-8 text-base" : "h-10 px-4 text-sm";
const colors = variant === "primary"
  ? "bg-primary text-primary-foreground shadow-sm hover:bg-primary/90"
  : "border border-input bg-background hover:bg-accent hover:text-accent-foreground shadow-sm";
---
<a href={href} class:list={[base, sizing, colors]}>
  <slot />
</a>